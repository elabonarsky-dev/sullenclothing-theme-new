<section class="tabbed-collections">
  <div class="container">
    {%- if section.settings.heading != blank -%}<h2 class="tabbed-collections__heading display">{{ section.settings.heading }}</h2>{%- endif -%}
    <tabbed-collections>
      <div class="tabbed-collections__tabs" role="tablist">
        {%- for block in section.blocks -%}
          <button type="button" role="tab" aria-selected="{% if forloop.first %}true{% else %}false{% endif %}" data-tab="{{ forloop.index0 }}">{{ block.settings.label }}</button>
        {%- endfor -%}
      </div>
      {%- for block in section.blocks -%}
        {%- assign coll = collections[block.settings.collection] -%}
        <div class="tabbed-collections__panel" role="tabpanel" data-panel="{{ forloop.index0 }}" {% unless forloop.first %}hidden{% endunless %}>
          <div class="product-rail">
            {%- for product in coll.products limit: 8 -%}
              {% render 'product-card', product: product %}
            {%- else -%}
              <p>No products yet.</p>
            {%- endfor -%}
          </div>
          <a href="{{ coll.url }}" class="btn btn--ghost">View all {{ block.settings.label }}</a>
        </div>
      {%- endfor -%}
    </tabbed-collections>
  </div>
</section>
{% schema %}
{"name":"Tabbed collections","settings":[{"type":"text","id":"heading","label":"Heading","default":"Shop"}],"blocks":[{"type":"tab","name":"Tab","settings":[{"type":"text","id":"label","label":"Label","default":"New"},{"type":"collection","id":"collection","label":"Collection"}]}],"presets":[{"name":"Tabbed collections","blocks":[{"type":"tab"},{"type":"tab"},{"type":"tab"}]}]}
{% endschema %}
