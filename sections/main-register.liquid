<section class="auth container">
  <h1 class="display">{{ 'customer.register.title' | t }}</h1>
  {% form 'create_customer', class: 'auth__form' %}
    {{ form.errors | default_errors }}
    <label>{{ 'customer.register.first_name' | t }}<input type="text" name="customer[first_name]" required></label>
    <label>{{ 'customer.register.last_name' | t }}<input type="text" name="customer[last_name]" required></label>
    <label>{{ 'customer.login.email' | t }}<input type="email" name="customer[email]" required></label>
    <label>{{ 'customer.login.password' | t }}<input type="password" name="customer[password]" required></label>
    <button type="submit" class="btn btn--primary">{{ 'customer.register.submit' | t }}</button>
  {% endform %}
</section>
{% schema %}{"name":"Register","settings":[]}{% endschema %}
