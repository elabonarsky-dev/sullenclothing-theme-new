<section class="featured-bundle">
  <div class="container featured-bundle__inner">
    <div class="featured-bundle__copy">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="display">{{ section.settings.heading }}</h2>
      <p>{{ section.settings.body }}</p>
      <a href="{{ collections[section.settings.collection].url }}" class="btn btn--primary">{{ section.settings.cta_label }}</a>
    </div>
    <div class="product-rail product-rail--bundle">
      {%- for product in collections[section.settings.collection].products limit: 4 -%}
        {% render 'product-card', product: product, show_bundle_picker: true %}
      {%- endfor -%}
    </div>
  </div>
</section>
{% schema %}
{"name":"Featured bundle","settings":[
  {"type":"text","id":"eyebrow","label":"Eyebrow","default":"Bundle & Save"},
  {"type":"text","id":"heading","label":"Heading","default":"Buy 3, get cheapest free"},
  {"type":"textarea","id":"body","label":"Body"},
  {"type":"collection","id":"collection","label":"Collection"},
  {"type":"text","id":"cta_label","label":"CTA","default":"Build your bundle"}
],"presets":[{"name":"Featured bundle"}]}
{% endschema %}
