<section class="social-feed">
  <div class="container">
    <h2 class="display">{{ section.settings.heading }}</h2>
    <p class="social-feed__handle">@{{ settings.social_handle }}</p>
    <div class="social-feed__grid">
      {%- assign coll = collections[section.settings.source_collection] -%}
      {%- for product in coll.products limit: 8 -%}
        {%- assign img = product.images[1] | default: product.featured_image -%}
        <a href="{{ product.url }}" class="social-feed__tile">
          {% render 'responsive-image', image: img, sizes: '(min-width: 750px) 25vw, 50vw' %}
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>
{% schema %}
{"name":"Social feed","settings":[
  {"type":"text","id":"heading","label":"Heading","default":"On the streets"},
  {"type":"collection","id":"source_collection","label":"Source collection (tees)"}
],"presets":[{"name":"Social feed"}]}
{% endschema %}
