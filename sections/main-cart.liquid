<section class="cart-page container">
  <h1 class="display">{{ 'general.cart.title' | t }}</h1>
  {%- if cart.item_count == 0 -%}
    <p>{{ 'general.cart.empty' | t }}</p>
    <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">Continue shopping</a>
  {%- else -%}
    <form action="{{ routes.cart_url }}" method="post" novalidate>
      <ul class="cart-page__lines">
        {%- for line in cart.items -%}
          <li>{% render 'cart-line-item', line: line, index: forloop.index %}</li>
        {%- endfor -%}
      </ul>
      <div class="cart-page__footer">
        <p class="cart-page__subtotal">{{ 'general.cart.subtotal' | t }}: <strong>{{ cart.total_price | money }}</strong></p>
        <button type="submit" name="checkout" class="btn btn--primary">{{ 'general.cart.checkout' | t }}</button>
      </div>
    </form>
  {%- endif -%}
</section>
{% schema %}{"name":"Cart","settings":[]}{% endschema %}
