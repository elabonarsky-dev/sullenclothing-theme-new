<footer class="site-footer">
  <div class="container site-footer__grid">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'menu' -%}
          <div class="site-footer__col" {{ block.shopify_attributes }}>
            <h4 class="site-footer__heading">{{ block.settings.title }}</h4>
            <ul>
              {%- for link in linklists[block.settings.menu].links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </div>
        {%- when 'newsletter' -%}
          <div class="site-footer__col site-footer__col--newsletter" {{ block.shopify_attributes }}>
            <h4 class="site-footer__heading">{{ block.settings.heading }}</h4>
            <p>{{ block.settings.body }}</p>
            {% form 'customer', class: 'newsletter-form' %}
              <input type="hidden" name="contact[tags]" value="newsletter">
              <label class="visually-hidden" for="NewsletterEmail">Email</label>
              <input id="NewsletterEmail" type="email" name="contact[email]" placeholder="Email address" required>
              <button type="submit">{{ 'general.newsletter.button' | t }}</button>
              {%- if form.posted_successfully? -%}
                <p class="newsletter-form__success">{{ 'general.newsletter.success' | t }}</p>
              {%- endif -%}
            {% endform %}
          </div>
        {%- when 'social' -%}
          <div class="site-footer__col" {{ block.shopify_attributes }}>
            <h4 class="site-footer__heading">Follow</h4>
            <div class="site-footer__social">
              {%- if settings.social_instagram != blank -%}<a href="{{ settings.social_instagram }}" aria-label="Instagram">{% render 'icon-instagram' %}</a>{%- endif -%}
              {%- if settings.social_facebook != blank -%}<a href="{{ settings.social_facebook }}" aria-label="Facebook">{% render 'icon-facebook' %}</a>{%- endif -%}
              {%- if settings.social_youtube != blank -%}<a href="{{ settings.social_youtube }}" aria-label="YouTube">{% render 'icon-youtube' %}</a>{%- endif -%}
              {%- if settings.social_tiktok != blank -%}<a href="{{ settings.social_tiktok }}" aria-label="TikTok">{% render 'icon-tiktok' %}</a>{%- endif -%}
            </div>
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>
  <div class="container site-footer__bottom">
    <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
    <ul class="site-footer__legal">
      <li><a href="/policies/privacy-policy">Privacy</a></li>
      <li><a href="/policies/terms-of-service">Terms</a></li>
      <li><a href="/pages/do-not-sell">Do Not Sell My Info</a></li>
    </ul>
  </div>
</footer>
{% schema %}
{"name":"Footer","blocks":[
  {"type":"menu","name":"Menu","settings":[{"type":"text","id":"title","label":"Title","default":"Shop"},{"type":"link_list","id":"menu","label":"Menu"}]},
  {"type":"newsletter","name":"Newsletter","settings":[{"type":"text","id":"heading","label":"Heading","default":"Join the family"},{"type":"textarea","id":"body","label":"Body","default":"15% off your first order"}]},
  {"type":"social","name":"Social","settings":[]}
],"presets":[{"name":"Footer","blocks":[{"type":"menu"},{"type":"newsletter"},{"type":"social"}]}]}
{% endschema %}
