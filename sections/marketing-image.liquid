<section class="marketing-image" {% if section.settings.image %}style="--mi-image:url({{ section.settings.image | image_url: width: 1920 }});"{% endif %}>
  <div class="container marketing-image__content">
    <h2 class="display">{{ section.settings.heading }}</h2>
    {%- if section.settings.body != blank -%}<p>{{ section.settings.body }}</p>{%- endif -%}
    {%- if section.settings.cta_label != blank -%}<a href="{{ section.settings.cta_url }}" class="btn btn--primary">{{ section.settings.cta_label }}</a>{%- endif -%}
  </div>
</section>
{% schema %}
{"name":"Marketing image","settings":[
  {"type":"image_picker","id":"image","label":"Image"},
  {"type":"text","id":"heading","label":"Heading"},
  {"type":"textarea","id":"body","label":"Body"},
  {"type":"text","id":"cta_label","label":"CTA"},
  {"type":"url","id":"cta_url","label":"CTA URL"}
],"presets":[{"name":"Marketing image"}]}
{% endschema %}
