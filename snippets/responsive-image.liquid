{%- if image -%}
  <img
    src="{{ image | image_url: width: 800 }}"
    srcset="{{ image | image_url: width: 400 }} 400w,{{ image | image_url: width: 600 }} 600w,{{ image | image_url: width: 800 }} 800w,{{ image | image_url: width: 1200 }} 1200w,{{ image | image_url: width: 1600 }} 1600w"
    sizes="{{ sizes | default: '(min-width: 750px) 50vw, 100vw' }}"
    alt="{{ image.alt | default: '' | escape }}"
    loading="{{ loading | default: 'lazy' }}"
    width="{{ image.width }}"
    height="{{ image.height }}">
{%- endif -%}
